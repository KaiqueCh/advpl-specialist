#!/usr/bin/env bash
# advpl-specialist — PostToolUse hook
# Reads JSON from stdin, extracts tool_input.file_path, runs encoding conversion.

set -uo pipefail

INPUT=$(cat)

# Try jq first, fall back to sed
FILE_PATH=""
if command -v jq >/dev/null 2>&1; then
  FILE_PATH=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty' 2>/dev/null || true)
fi
if [ -z "$FILE_PATH" ]; then
  FILE_PATH=$(echo "$INPUT" | sed -n 's/.*"file_path"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n1)
fi

# Sanity guards
[ -z "$FILE_PATH" ] && exit 0
[ ! -f "$FILE_PATH" ] && exit 0

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB="$SCRIPT_DIR/lib/convert-encoding.sh"

if [ ! -f "$LIB" ]; then
  echo "advpl-specialist: encoding library not found at $LIB" >&2
  exit 0
fi

# shellcheck source=/dev/null
source "$LIB"

if ! process_file "$FILE_PATH"; then
  echo "advpl-specialist: encoding warning for $FILE_PATH" >&2
fi

exit 0
